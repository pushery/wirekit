# Files excluded from composer install / git archive (export-ignore)
# These files are only needed for development, not for end users.
/internal            export-ignore
/sample              export-ignore
/docs                export-ignore
/tests               export-ignore
/scripts             export-ignore
/.github             export-ignore
/.ai                 export-ignore
/.claude             export-ignore
/.idea               export-ignore
/.vscode             export-ignore
/node_modules        export-ignore
CLAUDE.md            export-ignore
PLAN.md              export-ignore
DEVELOPER.md         export-ignore
CHANGELOG-INTERNAL.md export-ignore
package.json         export-ignore
package-lock.json    export-ignore
.prettierrc          export-ignore
.prettierignore      export-ignore
eslint.config.mjs    export-ignore
phpstan.neon         export-ignore
testbench.yaml       export-ignore
pint.json            export-ignore
phpunit.xml          export-ignore
composer.lock        export-ignore
justfile             export-ignore
.gitattributes       export-ignore
.gitignore           export-ignore

# NOT export-ignore (must reach the end user):
# src/               → PHP source code
# resources/views/   → Blade templates
# resources/fonts/   → woff2 font files (GDPR-compliant)
# resources/js/      → Alpine source (for ESM users who self-bundle)
# dist/              → CSS + JS bundles
# config/            → Publishable config
# LICENSE            → Legal requirement
# README.md          → Package documentation
# CHANGELOG.md       → Public release history (per-version summaries)
# CONTRIBUTING.md    → Community guidelines
# composer.json      → Package definition
